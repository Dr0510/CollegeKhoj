/* ═══════════════════════════════════════════════════════════════
   🎨 CollegeKhoj Design System v2.0
   Single source of truth — Design tokens, components, utilities
   Inspired by Linear, Vercel, Stripe, Notion
   ═══════════════════════════════════════════════════════════════ */

@import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;550;600;700;800;900&display=swap');

/* ═══════════════════════════════════════════════════════════════
   1. DESIGN TOKENS
   ═══════════════════════════════════════════════════════════════ */
:root {
  --font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', system-ui, sans-serif;
  --font-mono: 'JetBrains Mono', 'SF Mono', 'Fira Code', monospace;
  --text-xs: 0.75rem; --text-sm: 0.875rem; --text-base: 1rem;
  --text-lg: 1.125rem; --text-xl: 1.25rem; --text-2xl: 1.5rem;
  --text-3xl: 2rem; --text-4xl: 2.5rem; --text-5xl: 3rem;
  --font-normal: 400; --font-medium: 500; --font-semibold: 600;
  --font-bold: 700; --font-extrabold: 800; --font-black: 900;
  --leading-tight: 1.15; --leading-normal: 1.5; --leading-relaxed: 1.65;
  --letter-wide: 0.02em; --letter-wider: 0.06em;

  --brand: #4f8ef7; --brand-hover: #3b75e0;
  --brand-muted: rgba(79,142,247,0.12); --brand-glow: rgba(79,142,247,0.18);
  --brand-gradient: linear-gradient(135deg, #4f8ef7 0%, #818cf8 100%);
  --brand-soft: linear-gradient(135deg, rgba(79,142,247,.12), rgba(79,142,247,.04));

  --safe: #22c55e; --safe-bg: rgba(34,197,94,0.12); --safe-border: rgba(34,197,94,0.28);
  --moderate: #f59e0b; --moderate-bg: rgba(245,158,11,0.12); --moderate-border: rgba(245,158,11,0.28);
  --ambitious: #818cf8; --ambitious-bg: rgba(129,140,248,0.12); --ambitious-border: rgba(129,140,248,0.28);
  --dream: #ec4899; --dream-bg: rgba(236,72,153,0.12); --dream-border: rgba(236,72,153,0.28);
  --info: #06b6d4; --info-bg: rgba(6,182,212,0.12);
  --success: #22c55e; --success-bg: rgba(34,197,94,0.12);
  --warning: #f59e0b; --warning-bg: rgba(245,158,11,0.12);
  --danger: #ef4444; --danger-bg: rgba(239,68,68,0.12);

  --space-0: 0; --space-1: 4px; --space-2: 8px; --space-3: 12px;
  --space-4: 16px; --space-5: 20px; --space-6: 24px; --space-8: 32px;
  --space-10: 40px; --space-12: 48px; --space-16: 64px; --space-20: 80px;

  --radius-sm: 6px; --radius-md: 10px; --radius-lg: 14px;
  --radius-xl: 16px; --radius-2xl: 20px; --radius-full: 9999px;

  --shadow-sm: 0 1px 3px rgba(0,0,0,0.06), 0 1px 2px rgba(0,0,0,0.04);
  --shadow-md: 0 4px 12px rgba(0,0,0,0.08), 0 2px 4px rgba(0,0,0,0.04);
  --shadow-lg: 0 10px 32px rgba(0,0,0,0.10), 0 4px 8px rgba(0,0,0,0.04);
  --shadow-xl: 0 20px 60px rgba(0,0,0,0.15), 0 8px 16px rgba(0,0,0,0.06);
  --shadow-glow: 0 8px 24px rgba(79,142,247,0.28);

  --duration-fast: 0.15s; --duration-normal: 0.25s; --duration-slow: 0.35s;
  --ease-out: cubic-bezier(0.16,1,0.3,1); --ease-in-out: cubic-bezier(0.65,0,0.35,1);
  --z-base: 0; --z-dropdown: 100; --z-sticky: 200;
  --z-navbar: 300; --z-overlay: 400; --z-modal: 500; --z-toast: 600;
  --nav-height: 64px;
}

[data-theme="dark"] {
  --bg-primary: #0A0F1E; --bg-secondary: #111827; --bg-elevated: #1A1F2E;
  --bg-card: #111827; --bg-input: #0A0F1E;
  --bg-surface: rgba(255,255,255,0.03); --bg-surface-md: rgba(255,255,255,0.05);
  --bg-surface-lg: rgba(255,255,255,0.07); --bg-navbar: rgba(10,15,30,0.92);
  --text-primary: #F1F5F9; --text-secondary: #94A3B8; --text-tertiary: #64748B;
  --text-placeholder: #475569;
  --border: #1E293B; --border-light: rgba(255,255,255,0.06); --border-strong: rgba(255,255,255,0.12);
  --star-off: #334155; --footer: #475569;
  --scrollbar-track: #0A0F1E; --scrollbar-thumb: #334155;
  --sidebar-bg: #0D1117; --sidebar-border: #1E293B;
  --skeleton-from: rgba(255,255,255,0.04); --skeleton-to: rgba(255,255,255,0.08);
}

[data-theme="light"] {
  --bg-primary: #F8FAFC; --bg-secondary: #FFFFFF; --bg-elevated: #FFFFFF;
  --bg-card: #FFFFFF; --bg-input: #F1F5F9;
  --bg-surface: #F8FAFC; --bg-surface-md: #F1F5F9; --bg-surface-lg: rgba(0,0,0,0.03);
  --bg-navbar: rgba(255,255,255,0.92);
  --text-primary: #0F172A; --text-secondary: #475569; --text-tertiary: #94A3B8;
  --text-placeholder: #CBD5E1;
  --border: #E2E8F0; --border-light: rgba(0,0,0,0.06); --border-strong: rgba(0,0,0,0.12);
  --star-off: #CBD5E0; --footer: #CBD5E1;
  --scrollbar-track: #F1F5F9; --scrollbar-thumb: #CBD5E1;
  --sidebar-bg: #F8FAFC; --sidebar-border: #E2E8F0;
  --skeleton-from: rgba(0,0,0,0.04); --skeleton-to: rgba(0,0,0,0.08);
}


/* ═══════════════════════════════════════════════════════════════
   2. BASE RESET & TYPOGRAPHY
   ═══════════════════════════════════════════════════════════════ */
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
html { scroll-behavior: smooth; -webkit-text-size-adjust: 100%; text-size-adjust: 100%; }
body { background: var(--bg-primary); color: var(--text-primary); font-family: var(--font-family); font-size: var(--text-base); line-height: var(--leading-normal); min-height: 100vh; -webkit-font-smoothing: antialiased; -moz-osx-font-smoothing: grayscale; overflow-x: hidden; }
h1, h2, h3, h4, h5, h6 { font-weight: var(--font-bold); line-height: var(--leading-tight); color: var(--text-primary); }
h1 { font-size: var(--text-3xl); font-weight: var(--font-extrabold); }
h2 { font-size: var(--text-2xl); font-weight: var(--font-bold); }
h3 { font-size: var(--text-xl); font-weight: var(--font-semibold); }
h4 { font-size: var(--text-lg); }
h5 { font-size: var(--text-base); }
h6 { font-size: var(--text-sm); }
p { color: var(--text-secondary); }
a { color: var(--brand); text-decoration: none; transition: color var(--duration-fast) var(--ease-out); }
a:hover { color: var(--brand-hover); }
img { max-width: 100%; height: auto; display: block; }
code { font-family: var(--font-mono); font-size: 0.875em; background: var(--bg-surface); padding: 0.2em 0.4em; border-radius: var(--radius-sm); }
::selection { background: var(--brand-muted); color: var(--brand); }
:focus-visible { outline: 2px solid var(--brand); outline-offset: 2px; border-radius: var(--radius-sm); }
::-webkit-scrollbar { width: 8px; height: 8px; }
::-webkit-scrollbar-track { background: var(--scrollbar-track); }
::-webkit-scrollbar-thumb { background: var(--scrollbar-thumb); border-radius: var(--radius-full); }
::-webkit-scrollbar-thumb:hover { background: var(--text-tertiary); }

/* ═══════════════════════════════════════════════════════════════
   3. BUTTONS
   ═══════════════════════════════════════════════════════════════ */
.btn { display: inline-flex; align-items: center; justify-content: center; gap: var(--space-2); font-family: var(--font-family); font-weight: var(--font-semibold); font-size: var(--text-sm); border: none; border-radius: var(--radius-md); padding: var(--space-2) var(--space-4); cursor: pointer; transition: all var(--duration-fast) var(--ease-out); text-decoration: none; white-space: nowrap; position: relative; overflow: hidden; line-height: 1.4; }
.btn:active { transform: scale(0.97); }
.btn:disabled { opacity: 0.5; cursor: not-allowed; pointer-events: none; }
.btn-primary { background: var(--brand-gradient); color: #fff; box-shadow: 0 3px 12px rgba(79,142,247,0.25); }
.btn-primary:hover { transform: translateY(-1px); box-shadow: var(--shadow-glow); color: #fff; }
.btn-ghost { background: transparent; color: var(--text-secondary); border: 1px solid var(--border); }

/* ═══════════════════════════════════════════════════════════════
   4. CARDS
   ═══════════════════════════════════════════════════════════════ */
.card { background: var(--bg-card); border: 1px solid var(--border); border-radius: var(--radius-lg); padding: var(--space-5); transition: all var(--duration-fast) var(--ease-out); }
.card-hover:hover { transform: translateY(-2px); box-shadow: var(--shadow-md); border-color: var(--border-strong); }
.card-glass { background: var(--bg-navbar); backdrop-filter: blur(16px); -webkit-backdrop-filter: blur(16px); border: 1px solid var(--border-light); }
.card-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: var(--space-4); gap: var(--space-3); }
.card-title { font-size: var(--text-sm); font-weight: var(--font-semibold); color: var(--text-primary); }
.card-body { color: var(--text-secondary); font-size: var(--text-sm); }
.card-footer { margin-top: var(--space-4); padding-top: var(--space-4); border-top: 1px solid var(--border); display: flex; align-items: center; gap: var(--space-2); }
.stat-card { background: var(--bg-card); border: 1px solid var(--border); border-radius: var(--radius-lg); padding: var(--space-5); transition: all var(--duration-fast) var(--ease-out); }
.stat-card:hover { border-color: var(--border-strong); box-shadow: var(--shadow-sm); }
.stat-card .stat-icon { width: 40px; height: 40px; border-radius: var(--radius-md); display: flex; align-items: center; justify-content: center; font-size: var(--text-lg); margin-bottom: var(--space-3); }
.stat-card .stat-label { font-size: var(--text-xs); color: var(--text-tertiary); text-transform: uppercase; letter-spacing: var(--letter-wide); font-weight: var(--font-semibold); }

/* ═══════════════════════════════════════════════════════════════
   5. BADGES & TAGS
   ═══════════════════════════════════════════════════════════════ */
.badge { display: inline-flex; align-items: center; gap: var(--space-1); padding: var(--space-1) var(--space-2); font-size: var(--text-xs); font-weight: var(--font-semibold); border-radius: var(--radius-sm); white-space: nowrap; line-height: 1.3; }
.badge-pill { border-radius: var(--radius-full); padding: var(--space-1) var(--space-3); }
.badge-safe { background: var(--safe-bg); color: var(--safe); border: 1px solid var(--safe-border); }
.badge-moderate { background: var(--moderate-bg); color: var(--moderate); border: 1px solid var(--moderate-border); }
.badge-ambitious { background: var(--ambitious-bg); color: var(--ambitious); border: 1px solid var(--ambitious-border); }
.badge-dream { background: var(--dream-bg); color: var(--dream); border: 1px solid var(--dream-border); }
.badge-info { background: var(--info-bg); color: var(--info); border: 1px solid rgba(6,182,212,0.25); }
.badge-success { background: var(--success-bg); color: var(--success); border: 1px solid rgba(34,197,94,0.25); }
.badge-warning { background: var(--warning-bg); color: var(--warning); border: 1px solid rgba(245,158,11,0.25); }

/* ═══════════════════════════════════════════════════════════════
   6. FORMS & INPUTS
   ═══════════════════════════════════════════════════════════════ */
.form-group { margin-bottom: var(--space-4); }
.form-label { display: block; font-size: var(--text-xs); font-weight: var(--font-semibold); color: var(--text-secondary); margin-bottom: var(--space-1); letter-spacing: var(--letter-wide); text-transform: uppercase; }
.form-input, .form-select, .form-textarea { width: 100%; background: var(--bg-input); border: 1px solid var(--border); border-radius: var(--radius-md); padding: var(--space-2) var(--space-3); color: var(--text-primary); font-family: var(--font-family); font-size: var(--text-sm); outline: none; transition: all var(--duration-fast) var(--ease-out); line-height: 1.5; }
.form-input:focus, .form-select:focus, .form-textarea:focus { border-color: var(--brand); box-shadow: 0 0 0 3px var(--brand-glow); }
.form-input::placeholder { color: var(--text-placeholder); }
.form-textarea { min-height: 80px; resize: vertical; }
.form-hint { font-size: var(--text-xs); color: var(--text-tertiary); margin-top: var(--space-1); }
.form-error { font-size: var(--text-xs); color: var(--danger); margin-top: var(--space-1); display: flex; align-items: center; gap: var(--space-1); }
.input-wrap { position: relative; }
.input-wrap .input-icon { position: absolute; left: var(--space-3); top: 50%; transform: translateY(-50%); color: var(--text-tertiary); font-size: var(--text-sm); pointer-events: none; }
.input-wrap .form-input { padding-left: var(--space-10); }
.pill-group { display: flex; flex-wrap: wrap; gap: var(--space-1); }
.pill-group input[type=radio], .pill-group input[type=checkbox] { display: none; }
.pill-group label { display: inline-flex; align-items: center; gap: var(--space-1); background: var(--bg-input); border: 1px solid var(--border); border-radius: var(--radius-full); padding: var(--space-1) var(--space-3); font-size: var(--text-xs); color: var(--text-secondary); cursor: pointer; user-select: none; transition: all var(--duration-fast) var(--ease-out); }
.pill-group label:hover { border-color: var(--brand); color: var(--brand); }
.pill-group input:checked + label { background: var(--brand); border-color: var(--brand); color: #fff; }
.check-group { display: inline-flex; align-items: center; gap: var(--space-2); cursor: pointer; font-size: var(--text-sm); color: var(--text-secondary); user-select: none; }
.check-group input[type=checkbox] { display: none; }

/* ═══════════════════════════════════════════════════════════════
   7. TABLES
   ═══════════════════════════════════════════════════════════════ */
.table-wrap { overflow-x: auto; background: var(--bg-card); border: 1px solid var(--border); border-radius: var(--radius-lg); }
table { width: 100%; border-collapse: collapse; }
table th, table td { padding: var(--space-3) var(--space-4); text-align: left; font-size: var(--text-sm); border-bottom: 1px solid var(--border); }
table th { background: var(--bg-surface); color: var(--text-tertiary); font-weight: var(--font-semibold); font-size: var(--text-xs); text-transform: uppercase; letter-spacing: var(--letter-wide); }
table tr:last-child td { border-bottom: none; }
table tbody tr:hover td { background: var(--brand-muted); }

.cutoff-table { font-size: var(--text-xs); }
.cutoff-table th, .cutoff-table td { padding: var(--space-2) var(--space-3); text-align: center; }

.cmp-table { font-size: var(--text-sm); }
.cmp-table th { background: var(--bg-card); padding: var(--space-4) var(--space-5); min-width: 180px; border-bottom: 2px solid var(--border); }
.cmp-table th:first-child { background: var(--bg-surface); color: var(--text-tertiary); font-size: var(--text-xs); text-transform: uppercase; letter-spacing: var(--letter-wider); min-width: 130px; }
.cmp-table td { padding: var(--space-3) var(--space-5); vertical-align: middle; }
.cmp-table td:first-child { background: var(--bg-surface); color: var(--text-tertiary); font-size: var(--text-xs); text-transform: uppercase; letter-spacing: var(--letter-wide); }
.cmp-table tr:last-child td { border-bottom: none; }
.best-val { color: var(--safe) !important; font-weight: var(--font-extrabold); }

/* ═══════════════════════════════════════════════════════════════
   8. NAVIGATION
   ═══════════════════════════════════════════════════════════════ */
.navbar { position: sticky; top: 0; z-index: var(--z-navbar); background: var(--bg-navbar); backdrop-filter: blur(20px) saturate(180%); -webkit-backdrop-filter: blur(20px) saturate(180%); border-bottom: 1px solid var(--border-light); }
.navbar-inner { max-width: 1200px; margin: 0 auto; padding: 0 var(--space-6); height: var(--nav-height); display: flex; align-items: center; justify-content: space-between; gap: var(--space-4); }
.navbar-brand { display: flex; align-items: center; gap: var(--space-2); text-decoration: none; flex-shrink: 0; }
.navbar-brand-icon { width: 34px; height: 34px; background: var(--brand-gradient); border-radius: var(--radius-md); display: flex; align-items: center; justify-content: center; font-size: var(--text-sm); color: #fff; box-shadow: 0 3px 10px rgba(79,142,247,0.25); }
.navbar-brand-text { font-size: var(--text-lg); font-weight: var(--font-extrabold); color: var(--text-primary); }
.navbar-brand-text span { color: var(--brand); }
.navbar-links { display: flex; align-items: center; gap: var(--space-1); }
.nav-link { padding: var(--space-2) var(--space-3); font-size: var(--text-xs); font-weight: var(--font-medium); color: var(--text-secondary); text-decoration: none; border-radius: var(--radius-sm); transition: all var(--duration-fast) var(--ease-out); white-space: nowrap; }
.nav-link:hover { color: var(--text-primary); background: var(--brand-muted); }
.nav-link.active { background: var(--brand); color: #fff; }
.navbar-auth { display: flex; align-items: center; gap: var(--space-2); flex-shrink: 0; }
.nav-btn { display: inline-flex; align-items: center; gap: var(--space-1); padding: var(--space-2) var(--space-4); font-size: var(--text-xs); font-weight: var(--font-semibold); text-decoration: none; border-radius: var(--radius-md); transition: all var(--duration-fast) var(--ease-out); white-space: nowrap; cursor: pointer; font-family: var(--font-family); }
.nav-btn-ghost { color: var(--text-secondary); background: transparent; border: 1px solid var(--border); }
.nav-btn-ghost:hover { color: var(--text-primary); border-color: var(--brand); }
.nav-btn-primary { color: #fff; background: var(--brand-gradient); box-shadow: 0 3px 12px rgba(79,142,247,0.25); }

/* User Menu */
.user-menu { position: relative; }
.user-avatar-btn { background: none; border: 2px solid transparent; border-radius: var(--radius-full); padding: 0; cursor: pointer; transition: all var(--duration-fast) var(--ease-out); width: 34px; height: 34px; display: flex; align-items: center; justify-content: center; }
.user-avatar-btn:hover { border-color: var(--brand); }
.user-avatar { width: 30px; height: 30px; border-radius: var(--radius-full); object-fit: cover; }
.user-avatar-fallback { width: 30px; height: 30px; border-radius: var(--radius-full); background: var(--brand-gradient); color: #fff; font-size: var(--text-xs); font-weight: var(--font-bold); display: flex; align-items: center; justify-content: center; }
.user-dropdown { position: absolute; top: calc(100% + 8px); right: 0; min-width: 220px; background: var(--bg-elevated); border: 1px solid var(--border); border-radius: var(--radius-md); box-shadow: var(--shadow-lg); opacity: 0; visibility: hidden; transform: translateY(-8px); transition: all var(--duration-fast) var(--ease-out); z-index: calc(var(--z-dropdown) + 1); }
.user-dropdown.open { opacity: 1; visibility: visible; transform: translateY(0); }
.user-dropdown-header { padding: var(--space-3) var(--space-4) var(--space-2); }
.user-dropdown-name { display: block; font-size: var(--text-sm); font-weight: var(--font-semibold); color: var(--text-primary); }
.user-dropdown-email { display: block; font-size: var(--text-xs); color: var(--text-tertiary); }
.user-dropdown-divider { height: 1px; background: var(--border); margin: var(--space-1) 0; }
.user-dropdown-item { display: flex; align-items: center; gap: var(--space-2); padding: var(--space-2) var(--space-4); font-size: var(--text-xs); color: var(--text-secondary); text-decoration: none; transition: all var(--duration-fast) var(--ease-out); cursor: pointer; background: none; width: 100%; border: none; text-align: left; font-family: var(--font-family); }
.user-dropdown-item i { width: 16px; text-align: center; }
.user-dropdown-item:hover { background: var(--brand-muted); color: var(--text-primary); }
.user-dropdown-logout { color: var(--danger) !important; }
.user-dropdown-logout:hover { background: var(--danger-bg) !important; color: var(--danger) !important; }

/* Mobile Nav */
.navbar-mobile-toggle { display: none; background: none; border: none; color: var(--text-secondary); font-size: var(--text-xl); cursor: pointer; padding: var(--space-2); }
.navbar-mobile-menu { display: none; background: var(--bg-elevated); border-top: 1px solid var(--border-light); max-height: 0; overflow: hidden; transition: max-height 0.3s var(--ease-out); }
.navbar-mobile-menu.open { display: block; max-height: 500px; }
.nav-link.mobile { display: block; padding: var(--space-3) var(--space-5); font-size: var(--text-sm); border-radius: 0; border-bottom: 1px solid var(--border-light); }


/* ═══════════════════════════════════════════════════════════════
   9. SIDEBAR (Admin)
   ═══════════════════════════════════════════════════════════════ */
.sidebar { width: 260px; background: var(--sidebar-bg); border-right: 1px solid var(--sidebar-border); display: flex; flex-direction: column; position: fixed; top: 0; left: 0; bottom: 0; z-index: var(--z-sticky); overflow: hidden; }
.sidebar-brand { display: flex; align-items: center; gap: var(--space-3); padding: var(--space-5) var(--space-5); font-size: var(--text-lg); font-weight: var(--font-extrabold); border-bottom: 1px solid var(--sidebar-border); text-decoration: none; color: var(--text-primary); flex-shrink: 0; }
.sidebar-brand-icon { width: 32px; height: 32px; background: var(--brand-gradient); border-radius: var(--radius-md); display: flex; align-items: center; justify-content: center; color: #fff; font-size: var(--text-sm); box-shadow: 0 3px 10px rgba(79,142,247,0.25); }
.sidebar-brand span { color: var(--brand); }
.sidebar-nav { flex: 1; padding: var(--space-3) 0; overflow-y: auto; }
.sidebar-section { padding: var(--space-3) var(--space-5) var(--space-1); font-size: 0.65rem; font-weight: var(--font-semibold); color: var(--text-tertiary); text-transform: uppercase; letter-spacing: 0.08em; }
.sidebar-link { display: flex; align-items: center; gap: var(--space-3); padding: var(--space-2) var(--space-5); margin: 1px var(--space-3); border-radius: var(--radius-md); color: var(--text-secondary); text-decoration: none; font-size: var(--text-sm); font-weight: var(--font-medium); transition: all var(--duration-fast) var(--ease-out); }
.sidebar-link:hover { background: var(--brand-muted); color: var(--text-primary); }
.sidebar-link.active { background: var(--brand); color: #fff; }
.sidebar-link i { width: 18px; text-align: center; font-size: var(--text-xs); }
.sidebar-footer { padding: var(--space-3) var(--space-3); border-top: 1px solid var(--sidebar-border); flex-shrink: 0; }
.main-content { margin-left: 260px; min-height: 100vh; padding: var(--space-8); }

@media (max-width: 768px) {
  .sidebar { width: 60px; overflow: visible; }
  .sidebar-brand span, .sidebar-link span, .sidebar-section, .sidebar-footer span { display: none; }
  .sidebar-brand { justify-content: center; padding: var(--space-4) 0; }
  .sidebar-link { justify-content: center; padding: var(--space-3); margin: 1px var(--space-1); }
  .sidebar-footer { padding: var(--space-2); }
  .sidebar-footer a { justify-content: center; }
  .main-content { margin-left: 60px; padding: var(--space-4); }
}

@media (max-width: 768px) {
  .navbar-links { display: none; }
  .navbar-mobile-toggle { display: block; }

/* ═══════════════════════════════════════════════════════════════
   10. LAYOUT & PAGE STRUCTURE
   ═══════════════════════════════════════════════════════════════ */
.container { max-width: 1200px; margin: 0 auto; padding: 0 var(--space-6); }
.container-sm { max-width: 800px; }
.container-lg { max-width: 1200px; margin: 0 auto; padding: 0 var(--space-6); }
.page-header { padding: var(--space-8) 0 var(--space-6); }
.page-header h1 { font-size: var(--text-2xl); font-weight: var(--font-extrabold); color: var(--text-primary); margin-bottom: var(--space-1); }
.page-header p { color: var(--text-secondary); font-size: var(--text-sm); }
.back-link { display: inline-flex; align-items: center; gap: var(--space-1); color: var(--text-tertiary); font-size: var(--text-xs); text-decoration: none; margin-bottom: var(--space-3); transition: color var(--duration-fast) var(--ease-out); }
.back-link:hover { color: var(--brand); }
.hero { padding: var(--space-12) 0 var(--space-8); text-align: center; }
.hero h1 { font-size: var(--text-3xl); font-weight: var(--font-extrabold); letter-spacing: -0.5px; margin-bottom: var(--space-2); }
.hero h1 span { color: var(--brand); }
.hero p { color: var(--text-secondary); font-size: var(--text-base); max-width: 600px; margin: 0 auto; }
.main-grid { display: grid; grid-template-columns: 340px 1fr; gap: var(--space-6); align-items: start; }
@media (max-width: 991px) { .main-grid { grid-template-columns: 1fr; } }
.stat-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: var(--space-4); margin-bottom: var(--space-8); }

@media (max-width: 640px) {
  .container, .container-lg { padding: 0 var(--space-4); }
  .hero { padding: var(--space-8) 0 var(--space-6); }
  .hero h1 { font-size: var(--text-2xl); }
  .page-header { padding: var(--space-5) 0 var(--space-4); }
}

footer { border-top: 1px solid var(--border-light); padding: var(--space-6) 0; margin-top: var(--space-12); text-align: center; color: var(--footer); font-size: var(--text-xs); }

/* ═══════════════════════════════════════════════════════════════
   11. TOAST NOTIFICATIONS
   ═══════════════════════════════════════════════════════════════ */
.toast-container { position: fixed; top: var(--space-5); right: var(--space-5); z-index: var(--z-toast); display: flex; flex-direction: column; gap: var(--space-2); pointer-events: none; }
.toast { pointer-events: auto; padding: var(--space-3) var(--space-4); background: var(--bg-elevated); border: 1px solid var(--border); border-radius: var(--radius-md); box-shadow: var(--shadow-lg); display: flex; align-items: center; gap: var(--space-2); font-size: var(--text-sm); color: var(--text-primary); min-width: 280px; max-width: 420px; animation: slideInRight var(--duration-normal) var(--ease-out); }
.toast-success { border-left: 3px solid var(--success); }
.toast-error { border-left: 3px solid var(--danger); }
.toast-info { border-left: 3px solid var(--brand); }
.toast .toast-icon { font-size: var(--text-lg); }
.toast-success .toast-icon { color: var(--success); }
.toast-error .toast-icon { color: var(--danger); }
.toast-info .toast-icon { color: var(--brand); }

/* ═══════════════════════════════════════════════════════════════
   12. ALERTS / FLASH MESSAGES
   ═══════════════════════════════════════════════════════════════ */

/* ═══════════════════════════════════════════════════════════════
   13. EMPTY STATES
   ═══════════════════════════════════════════════════════════════ */
.empty-state { text-align: center; padding: var(--space-16) var(--space-6); }
.empty-state-icon { width: 80px; height: 80px; margin: 0 auto var(--space-5); background: var(--brand-muted); border: 1px solid rgba(79,142,247,0.2); border-radius: var(--radius-full); display: flex; align-items: center; justify-content: center; font-size: var(--text-3xl); color: var(--brand); }
.empty-state h4 { font-size: var(--text-xl); font-weight: var(--font-bold); color: var(--text-primary); margin-bottom: var(--space-2); }
.empty-state p { color: var(--text-secondary); max-width: 380px; margin: 0 auto var(--space-6); font-size: var(--text-sm); }

/* ═══════════════════════════════════════════════════════════════
   14. CHANCE / MATCH BARS
   ═══════════════════════════════════════════════════════════════ */
.bar-wrap { background: var(--bg-surface-lg); border-radius: var(--radius-sm); height: 4px; margin-top: var(--space-1); overflow: hidden; }
.bar-fill { height: 4px; border-radius: var(--radius-sm); transition: width var(--duration-slow) var(--ease-out); }
.bar-safe { background: var(--safe); }
.bar-moderate { background: var(--moderate); }
.bar-ambitious { background: var(--ambitious); }
.bar-dream { background: var(--dream); }
.bar-brand { background: var(--brand-gradient); }
.stars-on { color: var(--moderate); }
.stars-off { color: var(--star-off); }

/* ═══════════════════════════════════════════════════════════════
   15. PAGINATION
   ═══════════════════════════════════════════════════════════════ */
.pagination { display: flex; align-items: center; gap: var(--space-1); justify-content: center; margin-top: var(--space-6); }
.pagination a, .pagination span { padding: var(--space-1) var(--space-3); border-radius: var(--radius-sm); font-size: var(--text-sm); text-decoration: none; color: var(--text-secondary); transition: all var(--duration-fast) var(--ease-out); }
.pagination a:hover { background: var(--brand-muted); color: var(--brand); }
.pagination .current { background: var(--brand); color: #fff; }

/* ═══════════════════════════════════════════════════════════════
   16. SKELETON LOADERS
   ═══════════════════════════════════════════════════════════════ */
@keyframes shimmer { 0% { background-position: -200% 0; } 100% { background-position: 200% 0; } }
.skeleton { background: linear-gradient(90deg, var(--skeleton-from) 25%, var(--skeleton-to) 50%, var(--skeleton-from) 75%); background-size: 200% 100%; animation: shimmer 1.5s infinite; border-radius: var(--radius-sm); }
.skeleton-text { height: 14px; margin-bottom: var(--space-2); width: 80%; }
.skeleton-text.short { width: 50%; }
.skeleton-card { height: 180px; border-radius: var(--radius-lg); margin-bottom: var(--space-3); }
.skeleton-avatar { width: 36px; height: 36px; border-radius: var(--radius-full); }

/* ═══════════════════════════════════════════════════════════════
   17. ANIMATIONS
   ═══════════════════════════════════════════════════════════════ */
@keyframes spin { to { transform: rotate(360deg); } }
@keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }
@keyframes fadeInUp { from { opacity: 0; transform: translateY(12px); } to { opacity: 1; transform: translateY(0); } }
@keyframes fadeInDown { from { opacity: 0; transform: translateY(-12px); } to { opacity: 1; transform: translateY(0); } }
@keyframes scaleIn { from { opacity: 0; transform: scale(0.95); } to { opacity: 1; transform: scale(1); } }
@keyframes slideInRight { from { transform: translateX(120%); } to { transform: translateX(0); } }
@keyframes pulse { 0%,100% { opacity: 1; } 50% { opacity: 0.5; } }

/* ═══════════════════════════════════════════════════════════════
   18. UTILITY CLASSES
   ═══════════════════════════════════════════════════════════════ */
.d-none { display: none !important; }
.d-flex { display: flex !important; }
.d-inline-flex { display: inline-flex !important; }
.d-grid { display: grid !important; }
.d-block { display: block !important; }
.flex-row { flex-direction: row !important; }
.flex-column { flex-direction: column !important; }
.flex-wrap { flex-wrap: wrap !important; }
.flex-1 { flex: 1 !important; }
.flex-shrink-0 { flex-shrink: 0 !important; }
.items-center { align-items: center !important; }
.items-start { align-items: flex-start !important; }
.items-end { align-items: flex-end !important; }
.justify-center { justify-content: center !important; }
.justify-between { justify-content: space-between !important; }
.justify-end { justify-content: flex-end !important; }
.gap-1 { gap: var(--space-1) !important; }
.gap-2 { gap: var(--space-2) !important; }
.gap-3 { gap: var(--space-3) !important; }
.gap-4 { gap: var(--space-4) !important; }
.gap-6 { gap: var(--space-6) !important; }
.m-0 { margin: 0 !important; }
.mt-0 { margin-top: 0 !important; }
.mt-1 { margin-top: var(--space-1) !important; }
.mt-2 { margin-top: var(--space-2) !important; }
.mt-3 { margin-top: var(--space-3) !important; }
.mt-4 { margin-top: var(--space-4) !important; }
.mt-6 { margin-top: var(--space-6) !important; }
.mt-8 { margin-top: var(--space-8) !important; }
.mb-0 { margin-bottom: 0 !important; }
.mb-1 { margin-bottom: var(--space-1) !important; }
.mb-2 { margin-bottom: var(--space-2) !important; }
.mb-3 { margin-bottom: var(--space-3) !important; }
.mb-4 { margin-bottom: var(--space-4) !important; }
.mb-6 { margin-bottom: var(--space-6) !important; }
.ml-auto { margin-left: auto !important; }
.mr-auto { margin-right: auto !important; }
.mx-auto { margin-left: auto !important; margin-right: auto !important; }
.p-0 { padding: 0 !important; }
.p-1 { padding: var(--space-1) !important; }
.p-2 { padding: var(--space-2) !important; }
.p-3 { padding: var(--space-3) !important; }
.p-4 { padding: var(--space-4) !important; }
.p-6 { padding: var(--space-6) !important; }
.px-2 { padding-left: var(--space-2) !important; padding-right: var(--space-2) !important; }
.px-3 { padding-left: var(--space-3) !important; padding-right: var(--space-3) !important; }
.px-4 { padding-left: var(--space-4) !important; padding-right: var(--space-4) !important; }
.py-2 { padding-top: var(--space-2) !important; padding-bottom: var(--space-2) !important; }
.py-3 { padding-top: var(--space-3) !important; padding-bottom: var(--space-3) !important; }
.py-4 { padding-top: var(--space-4) !important; padding-bottom: var(--space-4) !important; }
.py-6 { padding-top: var(--space-6) !important; padding-bottom: var(--space-6) !important; }
.w-full { width: 100% !important; }
.h-full { height: 100% !important; }
.rounded-sm { border-radius: var(--radius-sm) !important; }
.rounded-md { border-radius: var(--radius-md) !important; }
.rounded-lg { border-radius: var(--radius-lg) !important; }
.rounded-full { border-radius: var(--radius-full) !important; }
.border { border: 1px solid var(--border) !important; }
.border-0 { border: none !important; }
.text-xs { font-size: var(--text-xs) !important; }
.text-sm { font-size: var(--text-sm) !important; }
.text-base { font-size: var(--text-base) !important; }
.text-lg { font-size: var(--text-lg) !important; }
.text-xl { font-size: var(--text-xl) !important; }
.text-2xl { font-size: var(--text-2xl) !important; }
.font-normal { font-weight: var(--font-normal) !important; }
.font-medium { font-weight: var(--font-medium) !important; }
.font-semibold { font-weight: var(--font-semibold) !important; }
.font-bold { font-weight: var(--font-bold) !important; }
.font-extrabold { font-weight: var(--font-extrabold) !important; }
.text-left { text-align: left !important; }
.text-center { text-align: center !important; }
.text-right { text-align: right !important; }
.text-primary { color: var(--text-primary) !important; }
.text-secondary { color: var(--text-secondary) !important; }
.text-tertiary { color: var(--text-tertiary) !important; }

/* ═══════════════════════════════════════════════════════════════
   19. AUTH PAGES
   ═══════════════════════════════════════════════════════════════ */
.auth-page { display: flex; min-height: 100vh; }
.auth-left { flex: 1; background: var(--bg-secondary); display: flex; flex-direction: column; justify-content: center; padding: var(--space-12); position: relative; overflow: hidden; }
.auth-right { flex: 1; display: flex; align-items: center; justify-content: center; padding: var(--space-8); }
.auth-card-wrap { width: 100%; max-width: 440px; }
.auth-card { background: var(--bg-card); border: 1px solid var(--border); border-radius: var(--radius-xl); padding: var(--space-8); }
.auth-header { margin-bottom: var(--space-6); }
.auth-header h2 { font-size: var(--text-2xl); font-weight: var(--font-extrabold); margin-bottom: var(--space-1); }
.auth-header p { font-size: var(--text-sm); color: var(--text-secondary); }
.auth-divider { display: flex; align-items: center; gap: var(--space-3); margin: var(--space-5) 0; font-size: var(--text-xs); color: var(--text-tertiary); }
.auth-divider::before, .auth-divider::after { content: ''; flex: 1; height: 1px; background: var(--border); }
.social-login { display: grid; grid-template-columns: 1fr 1fr; gap: var(--space-3); }
.social-btn { display: flex; align-items: center; justify-content: center; gap: var(--space-2); padding: var(--space-2); border: 1px solid var(--border); border-radius: var(--radius-md); background: transparent; color: var(--text-secondary); font-size: var(--text-sm); font-weight: var(--font-medium); cursor: pointer; transition: all var(--duration-fast) var(--ease-out); font-family: var(--font-family); }
.social-btn:hover { border-color: var(--brand); color: var(--text-primary); background: var(--brand-muted); }
.switch-auth { text-align: center; margin-top: var(--space-5); font-size: var(--text-sm); color: var(--text-secondary); }
.switch-auth a { font-weight: var(--font-semibold); color: var(--brand); }
@media (max-width: 868px) { .auth-left { display: none; } .auth-right { flex: 1; padding: var(--space-4); } }

/* ═══════════════════════════════════════════════════════════════
   20. COMPARE BAR
   ═══════════════════════════════════════════════════════════════ */
.compare-bar { position: fixed; bottom: 24px; left: 50%; transform: translateX(-50%); background: var(--bg-elevated); border: 1px solid var(--border-strong); border-radius: var(--radius-full); box-shadow: var(--shadow-lg); padding: var(--space-2) var(--space-5); display: flex; align-items: center; gap: var(--space-3); z-index: var(--z-dropdown); white-space: nowrap; backdrop-filter: blur(16px); -webkit-backdrop-filter: blur(16px); }
.compare-bar-text { font-size: var(--text-sm); color: var(--text-primary); font-weight: var(--font-semibold); }

/* ═══════════════════════════════════════════════════════════════
   21. TOPBAR (Admin)
   ═══════════════════════════════════════════════════════════════ */
.topbar { display: flex; align-items: center; justify-content: space-between; margin-bottom: var(--space-8); padding-bottom: var(--space-4); border-bottom: 1px solid var(--border); }
.topbar h1 { font-size: var(--text-xl); font-weight: var(--font-bold); }
.topbar-right { display: flex; align-items: center; gap: var(--space-3); }

/* ═══════════════════════════════════════════════════════════════
   22. MAP SECTION
   ═══════════════════════════════════════════════════════════════ */
.map-section { background: var(--bg-card); border: 1px solid var(--border); border-radius: var(--radius-lg); padding: var(--space-4); margin-top: var(--space-4); }
.map-section h5 { font-size: var(--text-sm); font-weight: var(--font-bold); margin-bottom: var(--space-3); }
#map { height: 320px; border-radius: var(--radius-md); overflow: hidden; }

/* ═══════════════════════════════════════════════════════════════
   23. PRINT STYLES
   ═══════════════════════════════════════════════════════════════ */
@media print {
  .navbar, .sidebar, .compare-bar, footer, .btn, .college-actions, .result-toolbar, .card-actions, #map-section, .map-section { display: none !important; }
  body { background: #fff !important; color: #000 !important; }
  .college-card { break-inside: avoid; border: 1px solid #ddd !important; }
}

.text-brand { color: var(--brand) !important; }
.text-safe { color: var(--safe) !important; }
.text-error { color: var(--danger) !important; }
.text-white { color: #fff !important; }
.truncate { overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.sr-only { position: absolute; width: 1px; height: 1px; padding: 0; margin: -1px; overflow: hidden; clip: rect(0,0,0,0); border: 0; }
.cursor-pointer { cursor: pointer !important; }
.overflow-hidden { overflow: hidden !important; }
.pointer-events-none { pointer-events: none !important; }
@media (max-width: 640px) { .sm-d-none { display: none !important; } .sm-w-full { width: 100% !important; } }
@media (max-width: 768px) { .md-d-none { display: none !important; } }
@media (min-width: 992px) { .lg-d-none { display: none !important; } }


.animate-fade-in { animation: fadeIn var(--duration-normal) var(--ease-out) both; }
.animate-fade-in-up { animation: fadeInUp var(--duration-normal) var(--ease-out) both; }
.animate-fade-in-down { animation: fadeInDown var(--duration-normal) var(--ease-out) both; }
.animate-scale-in { animation: scaleIn var(--duration-normal) var(--ease-out) both; }
.animate-pulse { animation: pulse 2s var(--ease-in-out) infinite; }
.stagger-1 { animation-delay: 0.05s; }
.stagger-2 { animation-delay: 0.10s; }
.stagger-3 { animation-delay: 0.15s; }
.stagger-4 { animation-delay: 0.20s; }
.stagger-5 { animation-delay: 0.25s; }
.stagger-6 { animation-delay: 0.30s; }

.hover-lift { transition: transform var(--duration-fast) var(--ease-out), box-shadow var(--duration-fast) var(--ease-out); }
.hover-lift:hover { transform: translateY(-2px); box-shadow: var(--shadow-md); }

@media (prefers-reduced-motion: reduce) {
  *, *::before, *::after { animation-duration: 0.01ms !important; animation-iteration-count: 1 !important; transition-duration: 0.01ms !important; scroll-behavior: auto !important; }
}

.alert { padding: var(--space-3) var(--space-4); border-radius: var(--radius-md); margin-bottom: var(--space-3); display: flex; align-items: center; gap: var(--space-2); font-size: var(--text-sm); }
.alert-success { background: var(--success-bg); border: 1px solid rgba(34,197,94,0.25); color: var(--success); }
.alert-danger { background: var(--danger-bg); border: 1px solid rgba(239,68,68,0.25); color: var(--danger); }
.alert-info { background: var(--info-bg); border: 1px solid rgba(6,182,212,0.25); color: var(--info); }
.alert-warning { background: var(--warning-bg); border: 1px solid rgba(245,158,11,0.25); color: var(--warning); }

  .navbar-auth .nav-btn-ghost { display: none; }
}

/* ═══════════════════════════════════════════════════════════════
   24. PREMIUM HOMEPAGE SECTIONS
   ═══════════════════════════════════════════════════════════════ */

/* ── Premium Hero ── */
.premium-hero {
  position: relative;
  min-height: 85vh;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 6rem 2rem 4rem;
  overflow: hidden;
  background: var(--bg-primary);
}
.premium-hero::before {
  content: '';
  position: absolute;
  inset: 0;
  background: radial-gradient(ellipse 80% 60% at 0% 20%, rgba(79,142,247,0.08) 0%, transparent 60%),
              radial-gradient(ellipse 60% 50% at 100% 80%, rgba(129,140,248,0.06) 0%, transparent 60%);
  pointer-events: none;
}
.premium-hero-glow {
  position: absolute;
  top: -20%; right: -5%;
  width: 500px; height: 500px;
  background: radial-gradient(circle, rgba(79,142,247,0.15) 0%, transparent 70%);
  filter: blur(80px);
  opacity: 0.5;
  pointer-events: none;
}
.premium-hero-particles {
  position: absolute;
  inset: 0;
  overflow: hidden;
  pointer-events: none;
}
.premium-hero-particles span {
  position: absolute;
  width: 6px; height: 6px;
  background: var(--brand);
  border-radius: 50%;
  opacity: 0.2;
  animation: floatParticle 20s infinite linear;
}
.premium-hero-particles span:nth-child(1) { top: 20%; left: 10%; animation-delay: 0s; }
.premium-hero-particles span:nth-child(2) { top: 40%; left: 85%; animation-delay: -4s; width: 10px; height: 10px; opacity: 0.12; }
.premium-hero-particles span:nth-child(3) { top: 70%; left: 20%; animation-delay: -8s; }
.premium-hero-particles span:nth-child(4) { top: 15%; left: 65%; animation-delay: -12s; opacity: 0.08; width: 4px; height: 4px; }
.premium-hero-particles span:nth-child(5) { top: 80%; left: 75%; animation-delay: -16s; width: 8px; height: 8px; }
.premium-hero-particles span:nth-child(6) { top: 50%; left: 45%; animation-delay: -6s; width: 5px; height: 5px; opacity: 0.15; }

@keyframes floatParticle {
  0%   { transform: translateY(0) scale(1); opacity: 0.2; }
  50%  { transform: translateY(-100px) scale(1.4); opacity: 0.35; }
  100% { transform: translateY(0) scale(1); opacity: 0.2; }
}

.premium-hero-content {
  position: relative;
  z-index: 2;
  text-align: center;
  max-width: 820px;
  margin: 0 auto;
}
.premium-hero-badge {
  display: inline-flex;
  align-items: center;
  gap: 0.5rem;
  padding: 0.35rem 1rem 0.35rem 0.5rem;
  background: var(--brand-muted);
  border: 1px solid rgba(79,142,247,0.15);
  border-radius: var(--radius-full);
  font-size: var(--text-xs);
  font-weight: var(--font-semibold);
  color: var(--brand);
  margin-bottom: 1.5rem;
  animation: fadeInUp 0.6s var(--ease-out) both;
}
.premium-hero-badge .badge-dot {
  width: 8px; height: 8px;
  background: var(--safe);
  border-radius: 50%;
  animation: pulse 2s infinite;
}
.premium-hero h1 {
  font-size: clamp(2.5rem, 5.5vw, 4rem);
  font-weight: var(--font-black);
  line-height: 1.1;
  letter-spacing: -0.03em;
  color: var(--text-primary);
  margin-bottom: 1rem;
  animation: fadeInUp 0.6s var(--ease-out) 0.1s both;
}
.premium-hero h1 .text-gradient {
  background: var(--brand-gradient);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}
.premium-hero .hero-sub {
  font-size: var(--text-lg);
  line-height: 1.65;
  color: var(--text-secondary);
  max-width: 560px;
  margin: 0 auto 2rem;
  animation: fadeInUp 0.6s var(--ease-out) 0.15s both;
}

.nav-btn-primary:hover { transform: translateY(-1px); box-shadow: var(--shadow-glow); }

.check-box { width: 20px; height: 20px; border: 2px solid var(--border); border-radius: var(--radius-sm); display: inline-flex; align-items: center; justify-content: center; transition: all var(--duration-fast) var(--ease-out); flex-shrink: 0; }
.check-group input:checked + .check-box { background: var(--brand); border-color: var(--brand); color: #fff; font-size: var(--text-xs); }
.form-range { width: 100%; accent-color: var(--brand); height: 6px; border-radius: var(--radius-full); background: var(--bg-surface); cursor: pointer; }

.badge-danger { background: var(--danger-bg); color: var(--danger); border: 1px solid rgba(239,68,68,0.25); }
.tag { display: inline-flex; align-items: center; gap: var(--space-1); background: var(--bg-surface-md); border: 1px solid var(--border); border-radius: var(--radius-sm); padding: var(--space-1) var(--space-2); font-size: var(--text-xs); color: var(--text-secondary); }

.stat-card .stat-value { font-size: var(--text-2xl); font-weight: var(--font-extrabold); color: var(--text-primary); margin: var(--space-1) 0; }
.stat-card .stat-sub { font-size: var(--text-xs); color: var(--text-tertiary); }

.college-card { background: var(--bg-card); border: 1px solid var(--border); border-radius: var(--radius-lg); padding: var(--space-5); margin-bottom: var(--space-4); transition: all var(--duration-fast) var(--ease-out); }
.college-card:hover { border-color: var(--border-strong); box-shadow: var(--shadow-md); transform: translateY(-1px); }
.college-card-top { display: flex; justify-content: space-between; align-items: flex-start; gap: var(--space-3); margin-bottom: var(--space-3); }
.college-name { font-size: var(--text-base); font-weight: var(--font-semibold); color: var(--text-primary); line-height: var(--leading-tight); }
.college-meta { display: flex; flex-wrap: wrap; gap: var(--space-2); margin-bottom: var(--space-4); }
.college-stats { display: grid; grid-template-columns: repeat(auto-fit, minmax(100px, 1fr)); gap: var(--space-3); margin-bottom: var(--space-4); }
.college-stats .stat { text-align: center; padding: var(--space-2); background: var(--bg-surface); border-radius: var(--radius-md); }
.college-stats .stat .stat-lbl { font-size: 0.65rem; text-transform: uppercase; letter-spacing: var(--letter-wide); color: var(--text-tertiary); font-weight: var(--font-semibold); margin-bottom: var(--space-1); }
.college-stats .stat .stat-val { font-size: var(--text-sm); font-weight: var(--font-bold); color: var(--text-primary); }
.college-actions { display: flex; gap: var(--space-2); flex-wrap: wrap; }

.btn-ghost:hover { border-color: var(--brand); color: var(--brand); }
.btn-soft { background: var(--brand-muted); color: var(--brand); border: 1px solid transparent; }
.btn-soft:hover { background: rgba(79,142,247,0.18); color: var(--brand); }
.btn-danger { background: var(--danger); color: #fff; }
.btn-danger:hover { background: #dc2626; transform: translateY(-1px); }
.btn-success { background: var(--success); color: #fff; }
.btn-success:hover { background: #16a34a; transform: translateY(-1px); }
.btn-outline { background: transparent; border: 1px solid var(--border); color: var(--text-secondary); }
.btn-outline:hover { border-color: var(--text-primary); color: var(--text-primary); }
.btn-link { background: none; border: none; color: var(--brand); padding: 0; font-weight: var(--font-medium); }
.btn-link:hover { color: var(--brand-hover); text-decoration: underline; }
.btn-sm { padding: var(--space-1) var(--space-3); font-size: var(--text-xs); border-radius: var(--radius-sm); }
.btn-lg { padding: var(--space-3) var(--space-6); font-size: var(--text-base); border-radius: var(--radius-lg); }
.btn-icon { width: 36px; height: 36px; padding: 0; border-radius: var(--radius-md); border: 1px solid var(--border); background: transparent; color: var(--text-secondary); display: inline-flex; align-items: center; justify-content: center; cursor: pointer; font-size: var(--text-sm); transition: all var(--duration-fast) var(--ease-out); }
.btn-icon:hover { border-color: var(--brand); color: var(--brand); background: var(--brand-muted); }
.btn.loading .btn-text { opacity: 0; }
.btn-spinner { display: none; width: 16px; height: 16px; border: 2px solid rgba(255,255,255,0.3); border-top-color: #fff; border-radius: 50%; animation: spin 0.6s linear infinite; position: absolute; }
.btn.loading .btn-spinner { display: block; }


/* ── Hero Actions & Trust ── */
.premium-hero .hero-actions {
  display: flex;
  flex-wrap: wrap;
  gap: 0.75rem;
  justify-content: center;
  animation: fadeInUp 0.6s var(--ease-out) 0.25s both;
}
.premium-hero .hero-btn {
  padding: 0.8rem 2rem;
  border-radius: var(--radius-full);
  font-weight: var(--font-semibold);
  font-size: var(--text-sm);
  display: inline-flex;
  align-items: center;
  gap: 0.5rem;
  transition: all 0.3s var(--ease-out);
  cursor: pointer;
  font-family: var(--font-family);
  border: none;
  text-decoration: none;
}
.premium-hero .hero-btn-primary {
  background: var(--brand-gradient);
  color: #fff;
  box-shadow: 0 8px 28px rgba(79,142,247,0.3);
}
.premium-hero .hero-btn-primary:hover {
  transform: translateY(-3px);
  box-shadow: 0 12px 40px rgba(79,142,247,0.4);
}
.premium-hero .hero-btn-secondary {
  background: var(--bg-card);
  color: var(--text-primary);
  border: 1.5px solid var(--border);
  box-shadow: var(--shadow-sm);
}
.premium-hero .hero-btn-secondary:hover {

/* ── Section Wrappers ── */
.premium-section { padding: 5rem 2rem; position: relative; }
.premium-section-inner { max-width: 1200px; margin: 0 auto; width: 100%; }
.premium-section-header {
  text-align: center;
  max-width: 640px;
  margin: 0 auto 3.5rem;
}
.premium-section-header h2 {
  font-size: clamp(1.6rem, 3vw, 2.4rem);
  font-weight: var(--font-extrabold);
  color: var(--text-primary);
  letter-spacing: -0.02em;
  margin-bottom: 0.75rem;
  line-height: 1.2;
}
.premium-section-header p {
  font-size: var(--text-base);
  color: var(--text-secondary);
  line-height: 1.7;
}
.premium-section-alt { background: var(--bg-surface); }
[data-theme="dark"] .premium-section-alt { background: rgba(255,255,255,0.02); }
@media (max-width: 640px) {
  .premium-section { padding: 3rem 1rem; }
  .premium-section-header { margin-bottom: 2rem; }
}

/* ── Search Panel (Glassmorphism) ── */
.search-panel {
  background: var(--bg-navbar);
  backdrop-filter: blur(24px) saturate(180%);
  -webkit-backdrop-filter: blur(24px) saturate(180%);
  border: 1px solid var(--border-light);
  border-radius: var(--radius-xl);
  padding: var(--space-8);
  box-shadow: var(--shadow-lg);
}
.search-panel-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: var(--space-6);
  gap: var(--space-3);
  flex-wrap: wrap;
}
.search-panel-header h3 {
  font-size: var(--text-lg);
  font-weight: var(--font-bold);
  color: var(--text-primary);
  display: flex;
  align-items: center;
  gap: var(--space-2);
}
.search-panel-header h3 i { color: var(--brand); }
.search-panel-header .search-badge {
  background: var(--brand-muted);
  color: var(--brand);
  border-radius: var(--radius-full);
  padding: var(--space-1) var(--space-3);
  font-size: var(--text-xs);
  font-weight: var(--font-semibold);
  white-space: nowrap;
}
.search-grid { display: grid; grid-template-columns: 1fr 1fr; gap: var(--space-5); }
.search-grid .field-full { grid-column: 1 / -1; }

/* ── Features Grid ── */
.features-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
  gap: var(--space-5);
}
.feature-card {
  background: var(--bg-card);
  border: 1px solid var(--border);
  border-radius: var(--radius-lg);
  padding: var(--space-6);
  transition: all 0.3s var(--ease-out);
  position: relative;
  overflow: hidden;
}
.feature-card::before {
  content: '';
  position: absolute;
  top: 0; left: 0; right: 0;
  height: 3px;
  background: var(--brand-gradient);
  transform: scaleX(0);
  transform-origin: left;
  transition: transform 0.4s var(--ease-out);
}
.feature-card:hover { transform: translateY(-4px); box-shadow: var(--shadow-lg); border-color: var(--border-strong); }
.feature-card:hover::before { transform: scaleX(1); }
.feature-card .feature-icon {
  width: 48px; height: 48px;
  border-radius: var(--radius-md);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: var(--text-xl);
  margin-bottom: var(--space-4);
  background: var(--brand-muted);
  color: var(--brand);
}
.feature-card h4 {
  font-size: var(--text-base);
  font-weight: var(--font-bold);
  color: var(--text-primary);
  margin-bottom: var(--space-2);
}
.feature-card p { font-size: var(--text-sm); color: var(--text-secondary); line-height: 1.6; }

/* ── Stats Grid ── */
.stats-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: var(--space-6); }
.stat-item {
  text-align: center;
  padding: var(--space-8) var(--space-4);
  background: var(--bg-card);
  border: 1px solid var(--border);
  border-radius: var(--radius-lg);
  transition: all 0.3s var(--ease-out);
}
.stat-item:hover { transform: translateY(-2px); box-shadow: var(--shadow-md); border-color: var(--border-strong); }
.stat-item .stat-number {
  font-size: clamp(2rem, 4vw, 3rem);
  font-weight: var(--font-extrabold);
  background: var(--brand-gradient);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  line-height: 1;
  margin-bottom: var(--space-2);
}
.stat-item .stat-label {
  font-size: var(--text-sm);
  color: var(--text-secondary);
  font-weight: var(--font-medium);
}
@media (max-width: 768px) {
  .stats-grid { grid-template-columns: 1fr; gap: var(--space-4); }
  .stat-item { padding: var(--space-6); }
}

/* ── Premium Recommendation Cards ── */
.premium-recs-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: var(--space-6);
  flex-wrap: wrap;
  gap: var(--space-3);
.premium-rec-card {
  background: var(--bg-card);
  border: 1px solid var(--border);
  border-radius: var(--radius-lg);
  padding: var(--space-5);
  margin-bottom: var(--space-4);
  transition: all 0.3s var(--ease-out);
  position: relative;
  animation: fadeInUp 0.5s var(--ease-out) both;
}
.premium-rec-card:hover {
  transform: translateY(-2px);
  box-shadow: var(--shadow-lg);
  border-color: var(--border-strong);
}
.premium-rec-card-top {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: var(--space-3);
  margin-bottom: var(--space-3);
}
.premium-rec-card-top .rec-name {
  font-size: var(--text-base);
  font-weight: var(--font-bold);
  color: var(--text-primary);
  line-height: var(--leading-tight);
}
.premium-rec-card-top .rec-rank-badge {
  background: var(--moderate-bg);
  border: 1px solid var(--moderate-border);
  color: var(--moderate);
  border-radius: var(--radius-sm);
  padding: var(--space-1) var(--space-2);
  font-size: var(--text-xs);
  font-weight: var(--font-bold);
  white-space: nowrap;
  flex-shrink: 0;
}
.premium-rec-meta {
  display: flex;
  flex-wrap: wrap;
  gap: var(--space-2);
  margin-bottom: var(--space-4);
}
.premium-rec-meta .meta-tag {
  display: inline-flex;
  align-items: center;
  gap: var(--space-1);
  background: var(--bg-surface);
  border: 1px solid var(--border);
  border-radius: var(--radius-sm);
  padding: var(--space-1) var(--space-2);
  font-size: var(--text-xs);
  color: var(--text-secondary);
}
.premium-rec-stats {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: var(--space-3);
  margin-bottom: var(--space-4);
}
.premium-rec-stats .rec-stat {
  text-align: center;
  padding: var(--space-2);
  background: var(--bg-surface);
  border-radius: var(--radius-md);
}
.premium-rec-stats .rec-stat .rec-stat-label {
  font-size: 0.65rem;
  text-transform: uppercase;
  letter-spacing: var(--letter-wide);
  color: var(--text-tertiary);
  font-weight: var(--font-semibold);
  margin-bottom: var(--space-1);
}
.premium-rec-stats .rec-stat .rec-stat-value {
  font-size: var(--text-sm);
  font-weight: var(--font-bold);
  color: var(--text-primary);
}
.premium-rec-stats .rec-stat .rec-stat-value.fees { color: var(--safe); }
.premium-rec-stats .rec-stat .rec-stat-value.placement { color: var(--info); }
.premium-rec-stats .rec-stat .rec-stat-value.match { color: var(--brand); }

@media (max-width: 640px) {
  .premium-rec-stats { grid-template-columns: repeat(2, 1fr); }
  .premium-rec-card-top { flex-direction: column; }
}
.premium-recs-header h3 {
  font-size: var(--text-xl);
  font-weight: var(--font-bold);
  color: var(--text-primary);
  display: flex;
  align-items: center;
  gap: var(--space-2);
}
.premium-recs-header h3 i { color: var(--moderate); }
.premium-recs-count {
  background: var(--brand-muted);
  border: 1px solid rgba(79,142,247,0.2);
  border-radius: var(--radius-full);
  padding: var(--space-1) var(--space-3);
  font-size: var(--text-xs);
  color: var(--brand);
  font-weight: var(--font-semibold);
}

.search-grid .field-label {
  display: block;
  font-size: var(--text-xs);
  font-weight: var(--font-semibold);
  color: var(--text-secondary);
  margin-bottom: var(--space-1);
  letter-spacing: var(--letter-wide);
  text-transform: uppercase;
}
.search-grid .input-icon-wrap { position: relative; }
.search-grid .input-icon-wrap i {
  position: absolute;
  left: var(--space-3);
  top: 50%;
  transform: translateY(-50%);
  color: var(--text-tertiary);
  font-size: var(--text-sm);
  pointer-events: none;
}
.search-grid .input-icon-wrap .form-input { padding-left: var(--space-10); }
.search-grid .search-actions {
  grid-column: 1 / -1;
  display: flex;
  gap: var(--space-3);
  align-items: center;
  padding-top: var(--space-2);
}
.search-grid .search-actions .btn-primary-lg { flex: 1; }
.search-grid .result-count-badge {
  background: var(--brand-muted);
  border: 1px solid rgba(79,142,247,0.2);
  border-radius: var(--radius-full);
  padding: var(--space-2) var(--space-4);
  font-size: var(--text-sm);
  color: var(--brand);
  font-weight: var(--font-semibold);
  white-space: nowrap;
  display: flex;
  align-items: center;
  gap: var(--space-2);
}
@media (max-width: 768px) {
  .search-grid { grid-template-columns: 1fr; }
  .search-panel { padding: var(--space-5); }
  .search-grid .search-actions { flex-direction: column; }
  .search-grid .search-actions .btn-primary-lg { width: 100%; }
}

  border-color: var(--brand);
  color: var(--brand);
  transform: translateY(-3px);
  box-shadow: var(--shadow-md);
}
.premium-hero .hero-trust {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 2rem;
  flex-wrap: wrap;
  margin-top: 2.5rem;
  animation: fadeInUp 0.6s var(--ease-out) 0.35s both;
}
.premium-hero .trust-item {
  display: flex;
  align-items: center;
  gap: 0.5rem;
  font-size: var(--text-sm);
  color: var(--text-tertiary);
}
.premium-hero .trust-item i { color: var(--safe); font-size: var(--text-base); }
@media (max-width: 640px) {
  .premium-hero { padding: 5rem 1rem 3rem; min-height: auto; }
  .premium-hero h1 { font-size: clamp(1.8rem, 8vw, 2.4rem); }
  .premium-hero .hero-sub { font-size: var(--text-base); }
  .premium-hero .hero-btn { padding: 0.7rem 1.5rem; font-size: var(--text-xs); }
  .premium-hero .hero-trust { gap: 1rem; flex-direction: column; }
}

/* ── Premium Match Bar ── */
.premium-rec-match { margin-top: var(--space-3); }
.premium-rec-match .match-label {
  display: flex;
  justify-content: space-between;
  font-size: var(--text-xs);
  color: var(--text-tertiary);
  margin-bottom: var(--space-1);
}
.premium-rec-match .match-label strong { color: var(--brand); font-weight: var(--font-bold); }
.premium-rec-match .match-bar {
  height: 4px;
  background: var(--bg-surface-lg);
  border-radius: var(--radius-full);
  overflow: hidden;
}
.premium-rec-match .match-bar-fill {
  height: 100%;
  border-radius: var(--radius-full);
  background: var(--brand-gradient);
  transition: width 1s var(--ease-out);
}
.premium-rec-rating {
  display: inline-flex;
  align-items: center;
  gap: 0.15rem;
}
.premium-rec-rating i { font-size: var(--text-xs); }
.premium-rec-rating .star-on { color: var(--moderate); }
.premium-rec-rating .star-off { color: var(--star-off); }
.premium-rec-rating .rating-num {
  font-size: var(--text-xs);
  color: var(--text-tertiary);
  margin-left: var(--space-1);
}

/* ── Premium Empty State ── */
.premium-empty {
  text-align: center;
  padding: var(--space-16) var(--space-6);
  background: var(--bg-card);
  border: 1px solid var(--border);
  border-radius: var(--radius-xl);
  position: relative;
  overflow: hidden;
}
.premium-empty::before {
  content: '';
  position: absolute;
  top: 0; left: 0; right: 0;
  height: 4px;
  background: var(--brand-gradient);
  opacity: 0.5;
}
.premium-empty .empty-icon-wrap {
  width: 96px; height: 96px;
  margin: 0 auto var(--space-5);
  background: var(--brand-muted);
  border: 1px solid rgba(79,142,247,0.15);
  border-radius: var(--radius-full);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: var(--text-4xl);
  color: var(--brand);
  position: relative;
}
.premium-empty .empty-icon-wrap::after {
  content: '';
  position: absolute;
  inset: -4px;
  border-radius: var(--radius-full);
  border: 1.5px solid rgba(79,142,247,0.1);
  animation: pulse-ring 2s infinite;
}
@keyframes pulse-ring {
  0% { transform: scale(1); opacity: 0.6; }
  100% { transform: scale(1.08); opacity: 0; }
}
.premium-empty h4 {
  font-size: var(--text-xl);
  font-weight: var(--font-bold);
  color: var(--text-primary);
  margin-bottom: var(--space-2);
}
.premium-empty p {
  color: var(--text-secondary);
  max-width: 420px;
  margin: 0 auto var(--space-6);
  font-size: var(--text-sm);
  line-height: 1.6;
}
.premium-empty .empty-features {
  display: flex;
  flex-wrap: wrap;
  gap: var(--space-2);
  justify-content: center;
}
.premium-empty .empty-feature-chip {
  display: inline-flex;
  align-items: center;
  gap: var(--space-2);
  background: var(--bg-surface);
  border: 1px solid var(--border);
  border-radius: var(--radius-full);
  padding: var(--space-1) var(--space-4);
  font-size: var(--text-xs);
  color: var(--text-secondary);
  transition: all 0.2s var(--ease-out);
}
.premium-empty .empty-feature-chip:hover {
  border-color: var(--brand);
  color: var(--brand);
  background: var(--brand-muted);
}
.premium-empty .empty-feature-chip i { color: var(--brand); }

/* ── Premium Footer ── */
.premium-footer {
  border-top: 1px solid var(--border-light);
  padding: var(--space-8) var(--space-6);
  margin-top: var(--space-8);
}
.premium-footer-inner {
  max-width: 1200px;
  margin: 0 auto;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: var(--space-4);
  flex-wrap: wrap;
}
.premium-footer-brand {
  display: flex;
  align-items: center;
  gap: var(--space-2);
  font-size: var(--text-sm);
  font-weight: var(--font-semibold);
  color: var(--text-primary);
}
.premium-footer-brand i { color: var(--brand); }
.premium-footer-text { font-size: var(--text-xs); color: var(--text-tertiary); }
.premium-footer-links { display: flex; gap: var(--space-4); }
.premium-footer-links a {
  font-size: var(--text-xs);
  color: var(--text-tertiary);
  text-decoration: none;
  transition: color var(--duration-fast) var(--ease-out);
}
.premium-footer-links a:hover { color: var(--brand); }
@media (max-width: 640px) {
  .premium-footer-inner { flex-direction: column; text-align: center; }
  .premium-footer-links { justify-content: center; }
}

/* ── Scroll Reveal ── */
.reveal {
  opacity: 0;
  transform: translateY(30px);
  transition: opacity 0.7s var(--ease-out), transform 0.7s var(--ease-out);
}
.reveal.visible {
  opacity: 1;
  transform: translateY(0);
}
.reveal-delay-1 { transition-delay: 0.1s; }
.reveal-delay-2 { transition-delay: 0.2s; }
.reveal-delay-3 { transition-delay: 0.3s; }
.reveal-delay-4 { transition-delay: 0.4s; }

/* ── Full-width primary button ── */
.btn-primary-lg {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: var(--space-2);
  padding: var(--space-3) var(--space-6);
  background: var(--brand-gradient);
  color: #fff;
  border: none;
  border-radius: var(--radius-md);
  font-family: var(--font-family);
  font-weight: var(--font-semibold);
  font-size: var(--text-sm);
  cursor: pointer;
  transition: all var(--duration-fast) var(--ease-out);
  text-decoration: none;
  white-space: nowrap;
  line-height: 1.4;
  box-shadow: 0 3px 12px rgba(79,142,247,0.25);
}
.btn-primary-lg:hover {
  transform: translateY(-1px);
  box-shadow: var(--shadow-glow);
  color: #fff;
}

/* ── Stagger animation helper ── */
.stagger-1 { animation-delay: 0.05s; }
.stagger-2 { animation-delay: 0.10s; }
.stagger-3 { animation-delay: 0.15s; }
.stagger-4 { animation-delay: 0.20s; }
.stagger-5 { animation-delay: 0.25s; }
.stagger-6 { animation-delay: 0.30s; }

