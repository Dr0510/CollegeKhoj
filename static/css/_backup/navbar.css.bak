/* ============================================================
   🧭 CollegeKhoj Navbar — Part 1: Structure
   ============================================================ */

.ck-navbar {
  position: sticky;
  top: 0;
  z-index: var(--z-navbar);
  background: var(--bg-navbar);
  backdrop-filter: blur(16px);
  -webkit-backdrop-filter: blur(16px);
  border-bottom: 1px solid var(--border-primary);
}

.ck-navbar-inner {
  max-width: 1200px;
  margin: 0 auto;
  padding: 0 var(--space-6);
  height: 64px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: var(--space-4);
}

.ck-navbar-brand {
  display: flex;
  align-items: center;
  gap: var(--space-2);
  text-decoration: none;
  flex-shrink: 0;
}
.ck-navbar-brand-icon {
  width: 34px;
  height: 34px;
  background: var(--brand-gradient);
  border-radius: var(--radius-md);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: var(--text-sm);
  color: #fff;
  box-shadow: 0 3px 10px rgba(79, 142, 247, 0.25);
}
.ck-navbar-brand-text {
  font-size: var(--text-lg);
  font-weight: var(--font-extrabold);
  color: var(--text-primary);
}
.ck-navbar-brand-text span { color: var(--brand-primary); }

/* Desktop Nav Links */
.ck-navbar-links { display: flex; align-items: center; gap: var(--space-1); }
.ck-nav-link {
  padding: var(--space-2) var(--space-3);
  font-size: var(--text-xs);
  font-weight: var(--font-medium);
  color: var(--text-secondary);
  text-decoration: none;
  border-radius: var(--radius-sm);
  transition: all var(--duration-fast) var(--ease-out);
}
.ck-nav-link:hover {
  color: var(--text-primary);
  background: var(--brand-primary-muted);
}
.ck-nav-link.active {
  background: var(--brand-primary);
  border-color: var(--brand-primary);
  color: #fff;
}
.ck-nav-link.mobile {
  display: block;
  padding: var(--space-3) var(--space-5);
  font-size: var(--text-sm);
  border-radius: 0;
  border-bottom: 1px solid var(--border-primary);
}

/* ── Auth Buttons ── */
.ck-navbar-auth { display: flex; align-items: center; gap: var(--space-2); flex-shrink: 0; }
.ck-navbar-auth-buttons { display: flex; align-items: center; gap: var(--space-2); }

.ck-nav-btn {
  display: inline-flex;
  align-items: center;
  gap: var(--space-1);
  padding: var(--space-2) var(--space-4);
  font-size: var(--text-xs);
  font-weight: var(--font-semibold);
  text-decoration: none;
  border-radius: var(--radius-md);
  transition: all var(--duration-fast) var(--ease-out);
  white-space: nowrap;
  cursor: pointer;
  font-family: var(--font-family);
}
.ck-nav-btn-ghost {
  color: var(--text-secondary);
  background: transparent;
  border: 1px solid var(--border-primary);
}
.ck-nav-btn-ghost:hover {
  color: var(--text-primary);
  border-color: rgba(79, 142, 247, 0.3);
}
.ck-nav-btn-primary {
  color: #fff;
  background: var(--brand-gradient);
  box-shadow: 0 3px 12px rgba(79, 142, 247, 0.25);
}
.ck-nav-btn-primary:hover {
  transform: translateY(-1px);
  box-shadow: var(--shadow-glow);
}

/* ── User Menu ── */
.ck-user-menu { position: relative; }
.ck-user-avatar-btn {
  background: none;
  border: 2px solid transparent;
  border-radius: var(--radius-circle);
  padding: 0;
  cursor: pointer;
  transition: all var(--duration-fast) var(--ease-out);
  width: 34px;
  height: 34px;
  display: flex;
  align-items: center;
  justify-content: center;
}
.ck-user-avatar-btn:hover { border-color: var(--brand-primary); }
.ck-user-avatar {
  width: 30px;
  height: 30px;
  border-radius: var(--radius-circle);
  object-fit: cover;
}
.ck-user-avatar-fallback {
  width: 30px;
  height: 30px;
  border-radius: var(--radius-circle);
  background: var(--brand-gradient);
  color: #fff;
  font-size: var(--text-xs);
  font-weight: var(--font-bold);
  display: flex;
  align-items: center;
  justify-content: center;
}

/* ── Dropdown ── */
.ck-user-dropdown {
  position: absolute;
  top: calc(100% + 8px);
  right: 0;
  min-width: 220px;
  background: var(--bg-elevated);
  border: 1px solid var(--border-primary);
  border-radius: var(--radius-md);
  box-shadow: var(--shadow-lg);
  opacity: 0;
  visibility: hidden;
  transform: translateY(-8px);
  transition: all var(--duration-fast) var(--ease-out);
  z-index: calc(var(--z-dropdown) + 1);
}
.ck-user-dropdown.open { opacity: 1; visibility: visible; transform: translateY(0); }
.ck-user-dropdown-header { padding: var(--space-3) var(--space-4) var(--space-2); }
.ck-user-dropdown-name { display: block; font-size: var(--text-sm); font-weight: var(--font-semibold); color: var(--text-primary); }
.ck-user-dropdown-email { display: block; font-size: var(--text-xs); color: var(--text-tertiary); margin-top: 2px; }
.ck-user-dropdown-divider { height: 1px; background: var(--border-primary); margin: var(--space-1) 0; }
.ck-user-dropdown-item {
  display: flex;
  align-items: center;
  gap: var(--space-2);
  padding: var(--space-2) var(--space-4);
  font-size: var(--text-xs);
  color: var(--text-secondary);
  text-decoration: none;
  transition: all var(--duration-fast) var(--ease-out);
}
.ck-user-dropdown-item i { width: 16px; text-align: center; font-size: var(--text-xs); }
.ck-user-dropdown-item:hover { background: var(--brand-primary-muted); color: var(--text-primary); }
.ck-user-dropdown-logout { color: var(--color-error) !important; }
.ck-user-dropdown-logout:hover { background: var(--color-error-bg) !important; color: var(--color-error) !important; }

.ck-dropdown-backdrop { position: fixed; inset: 0; z-index: var(--z-dropdown); display: none; }
.ck-dropdown-backdrop.open { display: block; }

/* ── Mobile ── */
.ck-navbar-mobile-toggle { display: none; background: none; border: none; color: var(--text-secondary); font-size: var(--text-xl); cursor: pointer; padding: var(--space-2); }
.ck-navbar-mobile-toggle:hover { color: var(--text-primary); }
.ck-navbar-mobile-menu { display: none; background: var(--bg-elevated); border-top: 1px solid var(--border-primary); max-height: 0; overflow: hidden; transition: max-height 0.3s var(--ease-out); }
.ck-navbar-mobile-menu.open { display: block; max-height: 400px; }
.ck-navbar-mobile-divider { height: 1px; background: var(--border-primary); }
.ck-signup-mobile { color: var(--brand-primary) !important; font-weight: var(--font-semibold) !important; }

@media (max-width: 768px) {
  .ck-navbar-links { display: none; }
  .ck-navbar-auth-buttons .ck-nav-btn { padding: var(--space-2) var(--space-3); font-size: var(--text-xs); }
  .ck-navbar-auth-buttons .ck-nav-btn-ghost { display: none; }
  .ck-navbar-mobile-toggle { display: block; }
  .ck-navbar-mobile-menu.open { display: block; }
}
@media (max-width: 480px) {
  .ck-navbar-inner { padding: 0 var(--space-4); }
  .ck-navbar-brand-text { font-size: var(--text-base); }
  .ck-navbar-brand-icon { width: 30px; height: 30px; font-size: var(--text-xs); }
}

