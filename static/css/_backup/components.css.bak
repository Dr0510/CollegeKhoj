/* ============================================================
   🧩 CollegeKhoj Components — Part 1: Buttons
   ============================================================ */

/* ── Buttons ── */
.btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: var(--space-2);
  font-family: var(--font-family);
  font-weight: var(--font-semibold);
  border: none;
  cursor: pointer;
  transition: all var(--duration-fast) var(--ease-out);
  text-decoration: none;
  white-space: nowrap;
  position: relative;
  overflow: hidden;
}
.btn:active { transform: scale(0.98); }

.btn-primary {
  background: var(--brand-gradient);
  color: #fff;
  border-radius: var(--radius-md);
  padding: var(--space-3) var(--space-5);
  font-size: var(--text-sm);
  box-shadow: 0 3px 12px rgba(79, 142, 247, 0.25);
}
.btn-primary:hover {
  transform: translateY(-1px);
  box-shadow: var(--shadow-glow);
  color: #fff;
}

.btn-ghost {
  background: transparent;
  color: var(--text-secondary);
  border: 1px solid var(--border-primary);
  border-radius: var(--radius-md);
  padding: var(--space-2) var(--space-4);
  font-size: var(--text-sm);
}
.btn-ghost:hover { border-color: var(--brand-primary); color: var(--brand-primary); }
.btn-ghost.active {
  background: var(--brand-primary);
  border-color: var(--brand-primary);
  color: #fff;
}

.btn-sm { padding: var(--space-1) var(--space-3); font-size: var(--text-xs); border-radius: var(--radius-sm); }
.btn-lg { padding: var(--space-4) var(--space-6); font-size: var(--text-base); }

.btn-icon {
  width: 38px; height: 38px; padding: 0;
  border-radius: var(--radius-circle);
  border: 1px solid var(--border-primary);
  background: var(--bg-surface);
  color: var(--text-secondary);
  font-size: var(--text-sm);
  display: inline-flex; align-items: center; justify-content: center;
  cursor: pointer;
  transition: all var(--duration-fast) var(--ease-out);
}
.btn-icon:hover { border-color: var(--brand-primary); color: var(--brand-primary); }

.btn-card-action {
  flex: 1; min-width: 70px;
  display: inline-flex; align-items: center; justify-content: center;
  gap: var(--space-1);
  background: transparent;
  border: 1px solid var(--border-primary);
  color: var(--text-secondary);
  border-radius: var(--radius-sm);
  padding: var(--space-1) var(--space-2);
  font-size: var(--text-xs);
  cursor: pointer;
  transition: all var(--duration-fast) var(--ease-out);
  text-decoration: none;
  font-family: var(--font-family);
}
.btn-card-action:hover { border-color: var(--brand-primary); color: var(--brand-primary); }
.btn-card-action.bookmarked { border-color: var(--color-moderate); color: var(--color-moderate); }
.btn-card-action.in-compare {
  border-color: var(--color-ambitious);
  color: var(--color-ambitious);
  background: var(--color-ambitious-bg);
}

.btn-toolbar {
  display: inline-flex; align-items: center; gap: var(--space-1);
  background: transparent; border: 1px solid var(--border-primary);
  color: var(--text-secondary);
  border-radius: var(--radius-md);
  padding: var(--space-1) var(--space-3);
  font-size: var(--text-xs);
  cursor: pointer;
  transition: all var(--duration-fast) var(--ease-out);
  text-decoration: none;
  font-family: var(--font-family);
}
.btn-toolbar:hover { border-color: var(--brand-primary); color: var(--brand-primary); }

.btn-compare-go {
  background: var(--brand-gradient); border: none; color: #fff;
  border-radius: var(--radius-2xl);
  padding: var(--space-2) var(--space-5);
  font-size: var(--text-xs);
  font-weight: var(--font-bold);
  cursor: pointer;
  transition: all var(--duration-fast) var(--ease-out);
  font-family: var(--font-family);
}
.btn-compare-go:hover { box-shadow: var(--shadow-glow); transform: translateY(-1px); }

.btn-compare-clear {
  background: transparent; border: none;
  color: var(--text-tertiary);
  font-size: var(--text-xs);
  cursor: pointer;
  padding: var(--space-1);
  border-radius: var(--radius-sm);
  transition: color var(--duration-fast) var(--ease-out);
}
.btn-compare-clear:hover { color: var(--color-error); }

/* Button loading state */
.btn.loading .btn-text { opacity: 0; }
.btn.loading .btn-spinner { display: block; }
.btn-spinner {
  display: none; width: 18px; height: 18px;
  border: 2px solid rgba(255,255,255,0.3);
  border-top-color: #fff;
  border-radius: 50%;
  animation: spin 0.6s linear infinite;
  position: absolute;

/* ============================================================
   🧩 CollegeKhoj Components — Part 3: Badges & Tags
   ============================================================ */

.badge {
  display: inline-flex;
  align-items: center;
  gap: var(--space-1);
  padding: var(--space-1) var(--space-2);
  font-size: var(--text-xs);
  font-weight: var(--font-bold);
  border-radius: var(--radius-sm);
  white-space: nowrap;
}

.badge-pill {
  display: inline-flex;
  align-items: center;
  gap: var(--space-2);
  background: var(--brand-primary-muted);
  border: 1px solid rgba(79, 142, 247, 0.3);
  border-radius: var(--radius-2xl);
  padding: var(--space-1) var(--space-4);
  font-size: var(--text-xs);
  color: var(--brand-primary);
  font-weight: var(--font-semibold);
}

.chance-badge {
  flex-shrink: 0;
  border-radius: var(--radius-md);
  padding: var(--space-1) var(--space-3);
  font-size: var(--text-xs);
  font-weight: var(--font-extrabold);
  letter-spacing: var(--letter-space-wide);
}
.badge-safe     { background: var(--color-safe-bg);  border: 1px solid var(--color-safe-border);  color: var(--color-safe); }
.badge-moderate { background: var(--color-moderate-bg); border: 1px solid var(--color-moderate-border); color: var(--color-moderate); }
.badge-ambitious{ background: var(--color-ambitious-bg);border: 1px solid var(--color-ambitious-border);color: var(--color-ambitious); }
.badge-dream    { background: var(--color-dream-bg); border: 1px solid var(--color-dream-border); color: var(--color-dream); }

.results-count {
  background: var(--brand-primary-glow);
  border: 1px solid var(--brand-primary);
  color: var(--brand-primary);
  border-radius: var(--radius-2xl);
  padding: var(--space-1) var(--space-3);
  font-size: var(--text-xs);
  font-weight: var(--font-bold);
}

.meta-tag {
  background: var(--bg-surface-md);
  border: 1px solid var(--border-primary);
  border-radius: var(--radius-sm);
  padding: var(--space-1) var(--space-2);
  font-size: var(--text-xs);
  color: var(--text-secondary);
  display: inline-flex;
  align-items: center;
  gap: var(--space-1);
}

.rank-badge {
  background: var(--color-moderate-bg);
  border: 1px solid var(--color-moderate-border);
  color: var(--color-moderate);
  border-radius: var(--radius-md);
  padding: 2px var(--space-2);
  font-size: var(--text-xs);
  font-weight: var(--font-bold);
  white-space: nowrap;
}

.year-badge {
  background: var(--brand-primary-muted);
  border: 1px solid rgba(79, 142, 247, 0.25);
  color: var(--brand-primary);
  border-radius: var(--radius-sm);
  padding: var(--space-1) var(--space-2);
  font-size: var(--text-xs);
  font-weight: var(--font-bold);
}

.winner-tag {
  display: inline-block;
  background: var(--color-safe-bg);
  border: 1px solid var(--color-safe-border);
  color: var(--color-safe);
  border-radius: var(--radius-2xl);
  padding: 2px var(--space-2);
  font-size: var(--text-xs);
  font-weight: var(--font-bold);
  margin-left: var(--space-1);
}

.badge-required {
  background: var(--color-error-bg);
  border: 1px solid rgba(239, 68, 68, 0.25);
  color: var(--color-error);
  border-radius: var(--radius-sm);
  font-size: var(--text-xs);
  padding: 2px var(--space-1);
  margin-left: auto;
}

/* ── Progress / Chance bars ── */
.chance-bar-wrap, .match-bar-wrap {
  background: var(--bg-surface-lg);
  border-radius: var(--radius-sm);
  height: 4px;
  margin-top: var(--space-1);
  overflow: hidden;
}
.chance-bar, .match-bar {
  height: 4px;
  border-radius: var(--radius-sm);
  transition: width var(--duration-slow) var(--ease-out);
}
.bar-safe      { background: var(--color-safe); }
.bar-moderate  { background: var(--color-moderate); }
.bar-ambitious { background: var(--color-ambitious); }
.bar-dream     { background: var(--color-dream); }
.match-bar { background: var(--brand-gradient); }

.stars-on  { color: var(--color-moderate); font-size: var(--text-xs); }
.stars-off { color: var(--star-off); font-size: var(--text-xs); }

/* ── Legend ── */
.legend-bar { display: flex; flex-wrap: wrap; gap: var(--space-2); margin-bottom: var(--space-4); }
.legend-item {
  display: flex; align-items: center; gap: var(--space-1);
  background: var(--bg-card);
  border: 1px solid var(--border-primary);
  border-radius: var(--radius-md);
  padding: var(--space-1) var(--space-3);
  font-size: var(--text-xs);
  color: var(--text-secondary);
}
.legend-dot { width: 8px; height: 8px; border-radius: var(--radius-circle); flex-shrink: 0; }


/* ============================================================
   🧩 CollegeKhoj Components — Part 4: Forms & Inputs
   ============================================================ */

.form-label {
  font-size: var(--text-xs);
  font-weight: var(--font-semibold);
  color: var(--text-label);
  margin-bottom: var(--space-1);
  letter-spacing: var(--letter-space-wide);
  text-transform: uppercase;
  display: block;
}

.form-control, .form-select {
  background: var(--bg-input) !important;
  border: 1px solid var(--border-secondary) !important;
  color: var(--text-primary) !important;
  border-radius: var(--radius-md);
  font-size: var(--text-sm);
  padding: var(--space-2) var(--space-3);
  width: 100%;
  outline: none;
  font-family: var(--font-family);
  transition: border-color var(--duration-fast) var(--ease-out),
              box-shadow var(--duration-fast) var(--ease-out);
}
.form-control::placeholder { color: var(--text-placeholder); }
.form-control:focus, .form-select:focus {
  border-color: var(--brand-primary) !important;
  box-shadow: 0 0 0 3px var(--brand-primary-glow) !important;
}
.form-text {
  font-size: var(--text-xs);
  color: var(--text-tertiary);
  margin-top: var(--space-1);
}

.form-range {
  width: 100%;
  accent-color: var(--brand-primary);
  height: 6px;
  border-radius: var(--radius-full);
  background: var(--bg-surface);
  cursor: pointer;
}
select[multiple] { height: 96px; }

/* Pill group */
.pill-group { display: flex; flex-wrap: wrap; gap: var(--space-1); }
.pill-group input[type=radio], .pill-group input[type=checkbox] { display: none; }
.pill-group label {
  display: inline-flex; align-items: center; gap: var(--space-1);
  background: var(--bg-input);
  border: 1px solid var(--border-secondary);
  border-radius: var(--radius-2xl);
  padding: var(--space-1) var(--space-3);
  font-size: var(--text-xs);
  color: var(--text-secondary);
  cursor: pointer; user-select: none;
  transition: all var(--duration-fast) var(--ease-out);
}
.pill-group label:hover { border-color: var(--brand-primary); color: var(--brand-primary); }
.pill-group input:checked + label { background: var(--brand-primary); border-color: var(--brand-primary); color: #fff; }

.percentile-wrap { position: relative; }
.percentile-wrap .form-control { padding-right: 50px; font-size: var(--text-lg); font-weight: var(--font-bold); }
.percentile-suffix {
  position: absolute; right: 13px; top: 50%; transform: translateY(-50%);
  color: var(--text-tertiary); font-size: var(--text-xs);
  font-weight: var(--font-semibold); pointer-events: none;
}

.range-val {
  display: inline-block; background: var(--brand-primary); color: #fff;
  border-radius: var(--radius-2xl); padding: 2px var(--space-2);
  font-size: var(--text-xs); font-weight: var(--font-bold);
}

/* Custom checkbox */
.checkbox-group {
  display: inline-flex; align-items: center; gap: var(--space-2);
  cursor: pointer; font-size: var(--text-sm); color: var(--text-secondary); user-select: none;
}
.checkbox-group input[type=checkbox] { display: none; }
.check-box {
  width: 20px; height: 20px;
  border: 2px solid var(--border-secondary);
  border-radius: var(--radius-sm);
  display: inline-flex; align-items: center; justify-content: center;
  transition: all var(--duration-fast) var(--ease-out);
  color: transparent; font-size: var(--text-xs);
}
.checkbox-group input:checked + .check-box { background: var(--brand-primary); border-color: var(--brand-primary); color: #fff; }


/* ============================================================
   🧩 CollegeKhoj Components — Part 5: Tables & States
   ============================================================ */

/* ── Compare Table ── */
.compare-table-wrap { overflow-x: auto; margin-top: var(--space-5); }
table.cmp {
  width: 100%; border-collapse: separate; border-spacing: 0;
  border-radius: var(--radius-xl); overflow: hidden;
  border: 1px solid var(--border-primary);
}
.cmp th {
  background: var(--bg-card); padding: var(--space-4) var(--space-5);
  font-size: var(--text-xs); font-weight: var(--font-bold);
  color: var(--text-primary); border-bottom: 2px solid var(--border-primary);
  min-width: 190px;
}
.cmp th:first-child {
  background: var(--bg-surface); color: var(--text-tertiary);
  font-size: var(--text-xs); text-transform: uppercase;
  letter-spacing: var(--letter-space-wider); min-width: 130px;
}
.cmp td {
  padding: var(--space-3) var(--space-5); border-bottom: 1px solid var(--border-primary);
  font-size: var(--text-sm); color: var(--text-primary); vertical-align: middle;
}
.cmp td:first-child {
  background: var(--bg-surface); color: var(--text-tertiary);
  font-size: var(--text-xs); font-weight: var(--font-semibold);
  text-transform: uppercase; letter-spacing: var(--letter-space-wide);
}
.cmp tr:last-child td { border-bottom: none; }
.cmp tr:hover td:not(:first-child) { background: var(--brand-primary-muted); }
.best-val { color: var(--color-safe) !important; font-weight: var(--font-extrabold); }
.star-row { color: var(--color-moderate); }

/* ── Cutoff Table ── */
table.cutoff-table { width: 100%; border-collapse: collapse; font-size: var(--text-xs); }
.cutoff-table th {
  background: var(--bg-surface); color: var(--text-tertiary);
  font-size: var(--text-xs); text-transform: uppercase;
  letter-spacing: var(--letter-space-wider);
  padding: var(--space-2) var(--space-3); text-align: center;
  border-bottom: 1px solid var(--border-primary);
}
.cutoff-table td {
  padding: var(--space-2) var(--space-3); text-align: center;
  border-bottom: 1px solid var(--border-primary); color: var(--text-primary);
}
.cutoff-table tr:last-child td { border-bottom: none; }
.cutoff-table tr:hover td { background: var(--brand-primary-muted); }


/* ── Empty State ── */
.empty-state { text-align: center; padding: var(--space-16) var(--space-6); }
.icon-circle {
  width: 78px; height: 78px;
  background: var(--brand-primary-muted);
  border: 1px solid rgba(79, 142, 247, 0.2);
  border-radius: var(--radius-circle);
  display: inline-flex; align-items: center; justify-content: center;
  font-size: var(--text-3xl); color: var(--brand-primary);
  margin-bottom: var(--space-5);
}
.empty-state h4 { font-size: var(--text-xl); font-weight: var(--font-bold); color: var(--text-primary); margin-bottom: var(--space-2); }
.empty-state p { color: var(--text-secondary); max-width: 380px; margin: 0 auto var(--space-6); font-size: var(--text-sm); }
.feature-chips { display: flex; flex-wrap: wrap; gap: var(--space-2); justify-content: center; }
.feature-chip {
  background: var(--bg-card); border: 1px solid var(--border-primary);
  border-radius: var(--radius-2xl); padding: var(--space-1) var(--space-4);
  font-size: var(--text-xs); color: var(--text-secondary);
  display: flex; align-items: center; gap: var(--space-2);
}
.feature-chip i { color: var(--brand-primary); }

.step-list { display: inline-flex; flex-direction: column; gap: var(--space-2); text-align: left; }
.step-item {
  display: flex; align-items: center; gap: var(--space-3);
  background: var(--bg-card); border: 1px solid var(--border-primary);
  border-radius: var(--radius-md); padding: var(--space-2) var(--space-4);
  font-size: var(--text-xs); color: var(--text-secondary);
}
.step-num {
  width: 25px; height: 25px; background: var(--brand-gradient);
  border-radius: var(--radius-circle);
  display: flex; align-items: center; justify-content: center;
  font-size: var(--text-xs); font-weight: var(--font-extrabold); color: #fff; flex-shrink: 0;
}

/* ── Results Header ── */
.results-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: var(--space-4); }
.results-header h4 { font-size: var(--text-base); font-weight: var(--font-bold); color: var(--text-primary); margin: 0; }
.result-toolbar { display: flex; gap: var(--space-2); flex-wrap: wrap; }
.cutoff-note { font-size: var(--text-xs); color: var(--text-tertiary); margin-top: var(--space-2); }

/* ── Toast ── */
.toast-notif {
  position: fixed; top: 70px; right: 18px;
  background: var(--bg-card); border: 1px solid var(--brand-primary);
  border-radius: var(--radius-md); padding: var(--space-2) var(--space-4);
  font-size: var(--text-xs); color: var(--text-primary);
  z-index: var(--z-toast); box-shadow: var(--shadow-lg);
  display: flex; align-items: center; gap: var(--space-2);
  transform: translateX(120%);
  transition: transform var(--duration-normal) var(--ease-out);
}
.toast-notif.show { transform: translateX(0); }

/* ── Compare Bar ── */
.compare-bar {
  position: fixed; bottom: 24px; left: 50%; transform: translateX(-50%);
  background: var(--bg-card); border: 1px solid var(--brand-primary);
  border-radius: var(--radius-full);
  box-shadow: 0 8px 32px rgba(79, 142, 247, 0.25);
  padding: var(--space-2) var(--space-5);
  display: flex; align-items: center; gap: var(--space-3);
  z-index: var(--z-dropdown); white-space: nowrap;
}
.compare-bar-text { font-size: var(--text-xs); color: var(--text-primary); font-weight: var(--font-semibold); }
.compare-bar-text span { color: var(--brand-primary); }

/* ── Map ── */
#map-section { background: var(--bg-card); border: 1px solid var(--border-primary); border-radius: var(--radius-xl); padding: var(--space-4); margin-top: var(--space-4); }
#map-section h5 { font-size: var(--text-sm); font-weight: var(--font-bold); color: var(--text-primary); margin-bottom: var(--space-3); }
#map { height: 320px; border-radius: var(--radius-md); overflow: hidden; }

/* ── Alerts / Flash ── */
.flash-container { max-width: 1200px; margin: var(--space-3) auto; padding: 0 var(--space-4); }
.alert {
  padding: var(--space-3) var(--space-4); border-radius: var(--radius-md);
  margin-bottom: var(--space-3); display: flex; align-items: center;
  gap: var(--space-2); font-size: var(--text-sm);
}
.alert-success { background: var(--color-success-bg); border: 1px solid var(--color-safe-border); color: var(--color-safe); }
.alert-error,
.alert-danger  { background: var(--color-error-bg); border: 1px solid rgba(239, 68, 68, 0.25); color: var(--color-error); }
.alert-info    { background: var(--color-info-bg); border: 1px solid rgba(6, 182, 212, 0.25); color: var(--color-info); }

/* ── Print ── */
@media print {
  .navbar, .sidebar-card, .analysis-card, .card-actions,
  .compare-bar, #map-section, .results-header .result-toolbar,
  footer, .btn, .btn-toolbar { display: none !important; }
  .college-card { break-inside: avoid; border: 1px solid #ddd !important; border-left: 3px solid #000 !important; }
  body { background: #fff !important; color: #000 !important; }
}

/* ════════════════════════════════════════════════════════════
   🏛 Legacy Compatibility — Classes used by existing templates
   ════════════════════════════════════════════════════════════ */

/* ── Buttons ── */
.btn-brand {
  background: var(--brand-gradient);
  border: none; color: #fff; border-radius: var(--radius-md);
  padding: var(--space-3); font-weight: var(--font-bold);
  font-size: var(--text-sm); width: 100%;
  cursor: pointer; transition: all var(--duration-fast) var(--ease-out);
}
.btn-brand:hover {
  background: var(--brand-primary-hover);
  transform: translateY(-1px);
  box-shadow: var(--shadow-glow);
}

.btn-outline-sm {
  background: transparent; border: 1px solid var(--border-primary);
  color: var(--text-secondary); border-radius: var(--radius-sm);
  padding: var(--space-2) var(--space-4);
  font-size: var(--text-xs); font-weight: var(--font-semibold);
  cursor: pointer; transition: all var(--duration-fast) var(--ease-out);
  display: inline-flex; align-items: center; gap: var(--space-1);
  text-decoration: none;
}
.btn-outline-sm:hover { border-color: var(--brand-primary); color: var(--brand-primary); }
.btn-outline-sm.bookmarked { border-color: var(--color-moderate); color: var(--color-moderate); }

.btn-sm-action {
  flex: 1; min-width: 60px; display: inline-flex;
  align-items: center; justify-content: center; gap: var(--space-1);
  background: transparent; border: 1px solid var(--border-primary);
  color: var(--text-secondary); border-radius: var(--radius-sm);
  padding: var(--space-1) var(--space-2); font-size: var(--text-xs);
  cursor: pointer; transition: all var(--duration-fast) var(--ease-out);
  text-decoration: none;
}
.btn-sm-action:hover { border-color: var(--brand-primary); color: var(--brand-primary); }
.btn-sm-action.danger { color: var(--color-error); }
.btn-sm-action.danger:hover { border-color: var(--color-error); color: var(--color-error); }

/* ── Stat cards (grid) ── */
.stat-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(130px, 1fr));
  gap: var(--space-3); margin: var(--space-6) 0;
}
.stat-card {
  background: var(--bg-card);
  border: 1px solid var(--border-primary);
  border-radius: var(--radius-lg);
  padding: var(--space-4);
  text-align: center;
}
.stat-card .label { font-size: var(--text-xs); color: var(--text-tertiary); text-transform: uppercase; letter-spacing: var(--letter-space-wider); margin-bottom: var(--space-1); }
.stat-card .value { font-size: var(--text-xl); font-weight: var(--font-extrabold); color: var(--text-primary); }
.stat-card .sub { font-size: var(--text-xs); color: var(--text-tertiary); margin-top: var(--space-1); }
.stat-icon { font-size: var(--text-xl); margin-bottom: var(--space-2); }
.stat-num { font-size: var(--text-xl); font-weight: var(--font-extrabold); color: var(--text-primary); }
.stat-lbl { font-size: var(--text-xs); color: var(--text-tertiary); text-transform: uppercase; letter-spacing: var(--letter-space-wider); margin-top: var(--space-1); }

/* ── Meta pill (college profile) ── */
.meta-pill {
  display: inline-flex; align-items: center; gap: var(--space-1);
  background: var(--bg-surface); border: 1px solid var(--border-primary);
  border-radius: var(--radius-2xl); padding: var(--space-1) var(--space-4);
  font-size: var(--text-xs); color: var(--text-secondary);
}

/* ── Bookmarks page ── */
.college-grid { display: flex; flex-direction: column; gap: var(--space-3); }
.c-name { font-size: var(--text-sm); font-weight: var(--font-bold); color: var(--text-primary); margin-bottom: var(--space-2); }
.c-meta { display: flex; flex-wrap: wrap; gap: var(--space-1); margin-bottom: var(--space-3); }
.c-stats { display: grid; grid-template-columns: repeat(3, 1fr); gap: var(--space-2); margin-bottom: var(--space-3); }
.c-actions { display: flex; gap: var(--space-1); }
.s-box { background: var(--bg-surface); border-radius: var(--radius-sm); padding: var(--space-1); text-align: center; }
.s-lbl { font-size: var(--text-xs); color: var(--text-tertiary); text-transform: uppercase; letter-spacing: var(--letter-space-wider); }
.s-val { font-size: var(--text-sm); font-weight: var(--font-extrabold); color: var(--text-primary); }

/* ── Settings page ── */
.back-link-settings { color: var(--text-secondary); font-size: var(--text-xs); text-decoration: none; margin-bottom: var(--space-4); display: inline-flex; align-items: center; gap: var(--space-1); }
.back-link-settings:hover { color: var(--brand-primary); }

/* ── Profile page ── */
.profile-page { max-width: 800px; margin: 0 auto; padding: var(--space-4); }

/* ── Settings page container ── */
.settings-page { max-width: 800px; margin: 0 auto; padding: var(--space-4); }
.settings-container { background: var(--bg-card); border: 1px solid var(--border-primary); border-radius: var(--radius-xl); padding: var(--space-6); }